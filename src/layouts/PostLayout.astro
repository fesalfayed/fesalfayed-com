---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props { post: CollectionEntry<'blog'>; readingMinutes: number; headings: { depth: number; slug: string; text: string }[]; }
const { post, readingMinutes, headings } = Astro.props;
const { title, description, date, updated, tags, ogImage, canonicalUrl, toc } = post.data;
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const tocItems = headings.filter((h) => h.depth === 2 || h.depth === 3);
---
<BaseLayout title={`${title} — Fesal Fayed`} description={description} ogImage={ogImage} canonicalUrl={canonicalUrl} article>
  <article class="post">
    <header class="post-head">
      <p class="post-meta">
        <a href="/blog/">← writing</a>
        <span>·</span>
        <time datetime={date.toISOString()}>{fmt(date)}</time>
        {updated && <span>· updated {fmt(updated)}</span>}
        <span>·</span>
        <span>{readingMinutes} min read</span>
      </p>
      <h1>{title}</h1>
      <p class="post-desc">{description}</p>
      {tags.length > 0 && (
        <p class="post-tags">{tags.map((t) => <span class="tag">{t}</span>)}</p>
      )}
    </header>

    {toc && tocItems.length > 2 && (
      <nav class="toc" aria-label="Table of contents">
        <span class="toc-title">Contents</span>
        <ol>
          {tocItems.map((h) => (
            <li class={h.depth === 3 ? 'toc-sub' : ''}><a href={`#${h.slug}`}>{h.text}</a></li>
          ))}
        </ol>
      </nav>
    )}

    <div class="post-body">
      <slot />
    </div>
  </article>
</BaseLayout>

<style is:global>
  @import url('https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css');

  .post { max-width: var(--measure); margin: 0 auto; }
  .post-head { padding: 2.2222rem 0 0.5556rem; }
  .post-meta { font-family: var(--font-mono); font-weight: 500; font-size: 0.6667rem; color: var(--fg-dim); display: flex; gap: 0.5rem; flex-wrap: wrap; text-transform: uppercase; letter-spacing: var(--track-eyebrow); }
  .post-head h1 { font-size: clamp(1.8889rem, 4.5vw, 2.6667rem); letter-spacing: var(--track-display); margin: 0.6667rem 0; }
  .post-desc { font-size: 1.0556rem; line-height: 1.4; color: var(--fg-soft); font-style: italic; font-family: var(--font-body); }
  .post-tags { display: flex; gap: 0.4444rem; flex-wrap: wrap; }
  .tag { font-family: var(--font-mono); font-weight: 500; font-size: 0.6111rem; color: var(--fg-dim); border: 1px solid var(--line); border-radius: var(--radius-card); padding: 0.1rem 0.5rem; }

  .toc { border: 1px solid var(--line); border-left: 2px solid var(--accent); background: var(--bg-raise); padding: 1rem 1.3333rem; margin: 1.6667rem 0; font-size: 0.8333rem; }
  .toc-title { font-family: var(--font-display); font-size: 0.6111rem; text-transform: uppercase; letter-spacing: var(--track-eyebrow); color: var(--fg-dim); }
  .toc ol { margin: 0.5556rem 0 0; padding-left: 1.1111rem; }
  .toc li { margin: 0.1667rem 0; }
  .toc li a { color: var(--fg-soft); }
  .toc li a:hover { color: var(--accent); }
  .toc-sub { margin-left: 1rem; list-style-type: none; }

  .post-body { margin-top: 1.6667rem; }
  .post-body h2 { font-size: 1.5556rem; margin: 2.6667rem 0 0.8889rem; }
  .post-body h3 { font-size: 1.1667rem; margin: 2rem 0 0.6667rem; }
  .post-body h2 a, .post-body h3 a { color: inherit; }
  .post-body p { margin: 0.9444rem 0; }
  .post-body a { text-decoration: underline; text-underline-offset: 3px; text-decoration-color: var(--line); }
  .post-body a:hover { text-decoration-color: var(--accent); }
  .post-body img, .post-body video { max-width: 100%; border-radius: var(--radius-card); border: 1px solid var(--line); }
  .post-body blockquote { border-left: 2px solid var(--accent); margin: 1.3333rem 0; padding: 0.2222rem 0 0.2222rem 1.1111rem; color: var(--fg-soft); font-style: italic; }
  .post-body table { border-collapse: collapse; width: 100%; font-size: 0.8333rem; margin: 1.3333rem 0; }
  .post-body th { font-family: var(--font-display); font-size: 0.6111rem; font-weight: 400; text-transform: uppercase; letter-spacing: var(--track-eyebrow); color: var(--fg-dim); text-align: left; }
  .post-body th, .post-body td { border-bottom: 1px solid var(--line); padding: 0.5556rem 0.7778rem 0.5556rem 0; }
  .post-body hr { border: none; border-top: 1px solid var(--line); margin: 2.7778rem 0; }
  .post-body .footnotes { font-size: 0.8333rem; color: var(--fg-soft); }
  .post-body .footnotes hr { margin: 2.2222rem 0 1.1111rem; }
  .post-body figure { margin: 1.6667rem 0; }
  .post-body figcaption { font-family: var(--font-mono); font-weight: 500; font-size: 0.6667rem; color: var(--fg-dim); margin-top: 0.4444rem; }
  .katex-display { overflow-x: auto; padding: 0.3333rem 0; }
</style>
