---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props { post: CollectionEntry<'blog'>; readingMinutes: number; headings: { depth: number; slug: string; text: string }[]; }
const { post, readingMinutes, headings } = Astro.props;
const { title, description, date, updated, tags, ogImage, canonicalUrl, toc } = post.data;
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const tocItems = headings.filter((h) => h.depth === 2 || h.depth === 3);
---
<BaseLayout title={`${title} — Fesal Fayed`} description={description} ogImage={ogImage} canonicalUrl={canonicalUrl} article>
  <article class="post">
    <header class="post-head">
      <p class="post-meta">
        <a href="/blog/">← writing</a>
        <span>·</span>
        <time datetime={date.toISOString()}>{fmt(date)}</time>
        {updated && <span>· updated {fmt(updated)}</span>}
        <span>·</span>
        <span>{readingMinutes} min read</span>
      </p>
      <h1>{title}</h1>
      <p class="post-desc">{description}</p>
      {tags.length > 0 && (
        <p class="post-tags">{tags.map((t) => <span class="tag">{t}</span>)}</p>
      )}
    </header>

    {toc && tocItems.length > 2 && (
      <nav class="toc" aria-label="Table of contents">
        <span class="toc-title">Contents</span>
        <ol>
          {tocItems.map((h) => (
            <li class={h.depth === 3 ? 'toc-sub' : ''}><a href={`#${h.slug}`}>{h.text}</a></li>
          ))}
        </ol>
      </nav>
    )}

    <div class="post-body">
      <slot />
    </div>
  </article>
</BaseLayout>

<style is:global>
  @import url('https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css');

  .post { max-width: var(--measure); margin: 0 auto; }
  .post-head { padding: 2rem 0 0.5rem; }
  .post-meta { font-family: var(--font-mono); font-size: 0.75rem; color: var(--fg-dim); display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .post-head h1 { font-size: clamp(1.8rem, 4.5vw, 2.6rem); margin: 0.6rem 0; }
  .post-desc { font-size: 1.05rem; color: var(--fg-soft); font-style: italic; font-family: var(--font-display); }
  .post-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .tag { font-family: var(--font-mono); font-size: 0.68rem; color: var(--fg-dim); border: 1px solid var(--line); border-radius: 99px; padding: 0.08rem 0.55rem; }

  .toc { border: 1px solid var(--line); border-radius: var(--radius); background: var(--bg-raise); padding: 0.9rem 1.2rem; margin: 1.5rem 0; font-size: 0.85rem; }
  .toc-title { font-family: var(--font-mono); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--fg-dim); }
  .toc ol { margin: 0.5rem 0 0; padding-left: 1.1rem; }
  .toc li { margin: 0.15rem 0; }
  .toc-sub { margin-left: 1rem; list-style-type: circle; }

  .post-body { margin-top: 1.5rem; }
  .post-body h2 { font-size: 1.55rem; margin: 2.4rem 0 0.8rem; }
  .post-body h3 { font-size: 1.2rem; margin: 1.8rem 0 0.6rem; }
  .post-body h2 a, .post-body h3 a { color: inherit; }
  .post-body p { margin: 0.9rem 0; }
  .post-body img, .post-body video { max-width: 100%; border-radius: var(--radius); border: 1px solid var(--line); }
  .post-body blockquote { border-left: 3px solid var(--accent); margin: 1.2rem 0; padding: 0.2rem 0 0.2rem 1.1rem; color: var(--fg-soft); font-style: italic; }
  .post-body table { border-collapse: collapse; width: 100%; font-size: 0.88rem; margin: 1.2rem 0; }
  .post-body th { font-family: var(--font-mono); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--fg-dim); text-align: left; }
  .post-body th, .post-body td { border-bottom: 1px solid var(--line); padding: 0.5rem 0.7rem 0.5rem 0; }
  .post-body hr { border: none; border-top: 1px solid var(--line); margin: 2.5rem 0; }
  .post-body .footnotes { font-size: 0.85rem; color: var(--fg-soft); }
  .post-body .footnotes hr { margin: 2rem 0 1rem; }
  .post-body figure { margin: 1.5rem 0; }
  .post-body figcaption { font-family: var(--font-mono); font-size: 0.72rem; color: var(--fg-dim); margin-top: 0.4rem; }
  .katex-display { overflow-x: auto; padding: 0.3rem 0; }
</style>
