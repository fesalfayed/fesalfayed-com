{
  "name": "fesalfayed-com",
  "compatibility_date": "2026-05-27",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "build": {
    "command": "npm install && npm run build"
  },
  "routes": [
    { "pattern": "fesalfayed.com", "custom_domain": true },
    { "pattern": "www.fesalfayed.com", "custom_domain": true }
  ]
}
